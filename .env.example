# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mk_user:mk_pass@db:5432/mk_logistic

# ── JWT Auth ──────────────────────────────────────────────
SECRET_KEY=change-me-in-production-32-chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email (Yandex SMTP) ────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASSWORD=your_app_password
EMAIL_FROM=МК Логистик <your@yandex.ru>

# ── ЮKassa ────────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:8001
ENVIRONMENT=development

# ── Admin users (tg_ids of existing bot admins, comma-separated) ──
ADMIN_TG_IDS=123456789

# ── Manager emails (for new order notifications) ──────────
MANAGER_EMAILS=manager@example.com

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
